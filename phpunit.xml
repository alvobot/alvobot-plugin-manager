<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    bootstrap="tests/bootstrap.php"
    colors="true"
    verbose="true">

    <testsuites>
        <testsuite name="Legacy">
            <directory suffix="Test.php">./tests/legacy</directory>
        </testsuite>
        <!--
            BrainMonkey suite usa phpunit-brain-monkey.xml (bootstrap separado).
            Patchwork precisa ser carregado ANTES dos stubs WP — processos distintos garantem isso.
            Use: composer test:brain-monkey
        -->
        <testsuite name="Integration">
            <directory suffix="Test.php">./tests/integration</directory>
        </testsuite>
    </testsuites>

    <coverage>
        <include>
            <directory suffix=".php">./includes</directory>
        </include>
        <exclude>
            <directory>./vendor</directory>
        </exclude>
    </coverage>

    <php>
        <const name="WP_DEBUG" value="true"/>
    </php>
</phpunit>
