{
  "name": "alvobot/plugin-manager",
  "description": "WordPress plugin manager with AI-powered modules",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=7.4",
    "enshrined/svg-sanitize": "^0.22"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^3.0",
    "phpcompatibility/phpcompatibility-wp": "*",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpstan/phpstan": "*",
    "szepeviktor/phpstan-wordpress": "*",
    "rector/rector": "*",
    "brain/monkey": "*",
    "infection/infection": "*"
  },
  "autoload": {
    "psr-4": {
      "AlvoBotPro\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AlvoBotPro\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:legacy": "phpunit --testsuite=Legacy",
    "test:brain-monkey": "PHPUNIT_SUITE=brain-monkey phpunit --testsuite=BrainMonkey",
    "test:all": [
      "@test:legacy",
      "@test:brain-monkey"
    ],
    "stan": "phpstan analyse",
    "stan:baseline": "phpstan analyse --generate-baseline",
    "rector": "rector process",
    "rector:dry": "rector process --dry-run",
    "infection": "infection run",
    "infection:ci": "infection run --threads=max --min-msi=40 --min-covered-msi=65",
    "lint": [
      "@lint:php",
      "@lint:js"
    ],
    "lint:php": "phpcs",
    "lint:js": "biome check",
    "lint:fix": [
      "@lint:fix:php",
      "@lint:fix:js"
    ],
    "lint:fix:php": "phpcbf",
    "lint:fix:js": "biome check --fix"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "infection/extension-installer": true
    }
  }
}
