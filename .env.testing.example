# Copy to .env.testing and fill in your Local by Flywheel values.
# IMPORTANT: Change ALL credentials below - do not use these placeholder values!
DB_HOST=127.0.0.1
DB_PORT=10004
DB_NAME=local
DB_USER=root
DB_PASSWORD=YOUR_DB_PASSWORD
DB_TABLE_PREFIX=wp_
WP_URL=http://localhost:10003
WP_DOMAIN=plugin-developer
ADMIN_USERNAME=YOUR_ADMIN_USERNAME
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD
WP_ROOT_FOLDER=/path/to/local-sites/plugin-developer/app/public
